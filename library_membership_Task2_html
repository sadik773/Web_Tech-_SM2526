<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Libreary membership Regestration Form</title>
</head>
<body>
    
    <h2> Library Membership Registation Form</h2>

   <fieldset>
            <legend>Personal Information</legend>


            <p>
                <label for="fullname">Full Name:</label>
                <input type="text"  id="fullname"   name="fullname"  placeholder="Enter Your Full Name"  required>
            </p>


            <p>
                <label for="memberid>Membership ID:</label>
                <input type="text" id="memberid" name="memberid" placeholder="e.g., ID-12345" required>
            </p>


            <p>
                <label for="email">Email Adress:</label>
                <input type="email" id="email" name="email" placeholder="example@email.com" required>
            </p>


            <p>
                <label for="phone">Phone Number:</label>
                <input type="tel" id="phone" name="phone" placeholder="Enter phone number" required>
            </p>


            <p>
                <label for="dob">Date of Birth</label>
                <input type="date" id="dob" name="dob" required>
            </p>


            <p>
                <label>Gender:</label>
                <input type="radio" id="male" name="gender" value="Male">
                <label for="male">Male</label>

                
                <input type="radio" id="female" name="gender" value="Female">
                <label for="female">Female</label>
                
                <input type="radio" id="other" name="gender" value="Other">
                <label for="other">Other</label>
            </p>

        </fieldset>



  <fieldset>
            <legend>Membership Information</legend>


            <p>
                <label for="membership_type">Membership Type:</label>
                <select id="membership_type" name="membership_type">



                    <option value="student" selected>Student</option>

                    <option value="faculty">Faculty</option>

                    <option value="researcher">Researcher</option>

                    <option value="general">General Member</option>


                </select>
            </p>



            <p>
                <label for="library_section">Preferred Library Section:</label>

                <select id="library_section" name="library_section">


                    <option value="science_tech">Science & Technology</option>

                    <option value="literature">Literature</option>

                    <option value="business">Business Studies</option>

                    <option value="history">History</option>

                    <option value="arts_culture">Arts & Culture</option>


                </select>
            </p>


        </fieldset>  <br>




  <fieldset>
            <legend>Reading Preferences</legend>

            <p>Select Favorite Book Categories:</p>

            <input type="checkbox"  id="cat_fiction"   name="category" value="Fiction">
            <label for="cat_fiction">Fiction</label><br>

            
            <input type="checkbox" id="cat_nonfiction" name="category" value="Non-Fiction">
            <label for="cat_nonfiction">Non-Fiction</label><br>

            
            <input type="checkbox" id="cat_science" name="category" value="Science">
            <label for="cat_science">Science</label><br>

            
            <input type="checkbox" id="cat_tech" name="category" value="Technology">
            <label for="cat_tech">Technology</label><br>

            
            <input type="checkbox" id="cat_biography" name="category" value="Biography">
            <label for="cat_biography">Biography</label><br>

            
            <input type="checkbox" id="cat_history" name="category" value="History">
            <label for="cat_history">History</label>


  </fieldset><br>



<fieldset>

            <legend>Library Services</legend>
            <p>Select Services You Want to Use:</p>



            <input type="checkbox"  id="srv_borrow" name="services" value="Book Borrowing">
            <label for="srv_borrow">Book Borrowing</label><br>
            

            <input type="checkbox" id="srv_digital" name="services" value="Digital Library Access">
            <label for="srv_digital">Digital Library Access</label><br>

            
            <input type="checkbox" id="srv_room" name="services" value="Reading Room">
            <label for="srv_room">Reading Room</label><br>

            
            <input type="checkbox" id="srv_research" name="services" value="Research Assistance">
            <label for="srv_research">Research Assistance</label>


        </fieldset><br>

<fieldset>
            <legend>Additional Information</legend>


            <p>
                <label for="address">Current Address:</label><br>
                <textarea id="address" name="address" rows="3" cols="40" placeholder="Enter your full address"></textarea>
            </p>



            <p>
                <label for="emergency_phone">Emergency Contact Number:</label>
                <input type="tel" id="emergency_phone" name="emergency_phone" placeholder="Enter emergency contact">
            </p>


            <p>
                <label for="reason">Reason for Joining the Library:</label><br>
                <textarea id="reason" name="reason" rows="3" cols="40" placeholder="Why do you want to join?"></textarea>
            </p>


            <p>
                <label for="suggestions">Suggestions for Library Improvement (Max 250 characters):</label><br>
                <textarea id="suggestions" name="suggestions" rows="3" cols="40" maxlength="250" placeholder="Your suggestions..."></textarea>
            </p>

            
        </fieldset>

        <br>

        <button type="submit">Submit</button>
        <button type="reset">Reset</button>







    </from>
</body>
</html>
